# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
# NestJS
backend/dist/
backend/build/

# Next.js
frontend/.next/
frontend/out/

# SQLite databases (ignore all database files)
*.db
*.db-journal
*.db-wal
*.db-shm

# Prisma (generated client)
backend/src/generated/
backend/prisma/migrations/*/migration.sql
backend/prisma/migrations/*/README.md
backend/prisma/migrations/*/states.json
backend/prisma/migrations/*/migration_lock.toml

# Environment variables
# .env
# .env.local
# .env.development.local
# .env.test.local
# .env.production.local
backend/.env
frontend/.env.local

# TypeScript cache
*.tsbuildinfo

# Coverage
coverage/
.nyc_output/
*.lcov

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.~lock.*

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp

# Yarn
.yarn-integrity
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Dependency directories (redundant but explicit)
**/node_modules/

# Compiled output
*.js.map
*.d.ts.map

